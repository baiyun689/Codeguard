# Codeguard 环境变量示例。复制为 .env 并填入真实值(.env 已被 gitignore)。

# LLM 提供商:mock | claude | openai
# mock = 不调真实 LLM,返回假数据(默认,用于验证流水线连通)
CODEGUARD_PROVIDER=mock

# 模型名(provider=claude/openai 时生效)
CODEGUARD_MODEL=claude-sonnet-4-20250514

# API 密钥(provider=claude/openai 时必填)
CODEGUARD_API_KEY=

# 自定义 API 地址(走代理/兼容端点时填,否则留空用官方默认)
CODEGUARD_API_BASE_URL=

# LLM 调用最大重试次数
CODEGUARD_MAX_RETRIES=3
