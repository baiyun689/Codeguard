# Codeguard 环境变量示例。复制为 .env 并填入真实值(.env 已被 gitignore)。

# LLM 提供商:openai(默认) | claude | mock
# openai = 默认,调真实 OpenAI(或兼容端点)API,需配 CODEGUARD_API_KEY
# claude = 调 Anthropic API
# mock   = 不调真实 LLM,返回假数据(零成本验证流水线连通)
CODEGUARD_PROVIDER=openai

# 模型名(留空则按 provider 自动回退:openai→gpt-4o-mini,claude→claude-sonnet-4-20250514)
# ★ DeepSeek 用户注意:deepseek-chat / deepseek-reasoner 将于 2026-07-24 下线,务必改用:
#   deepseek-v4-pro(= 原 deepseek-chat 的替代,全能力) 或 deepseek-v4-flash(轻量,替代 reasoner)
#   示例:CODEGUARD_MODEL=deepseek-v4-pro
CODEGUARD_MODEL=gpt-4o-mini

# API 密钥(provider=openai/claude 时必填)。切勿把真实密钥写进本示例文件,请写到 .env。
CODEGUARD_API_KEY=

# 自定义 API 地址(走代理 / OpenAI 兼容端点如 DeepSeek 时填,否则留空用官方默认)
# DeepSeek 示例:https://api.deepseek.com (注意不带 /v1 后缀)
CODEGUARD_API_BASE_URL=

# 结构化输出方式:function_calling(默认,兼容性最好) | json_schema | json_mode
# 注意:DeepSeek 等不支持 OpenAI 的 json_schema(response_format),务必用 function_calling。
CODEGUARD_STRUCTURED_METHOD=function_calling

# 是否禁用思考模式(true/false)。DeepSeek 推理模型默认开启 thinking,会与 function_calling
# /结构化输出冲突,用 DeepSeek 时设为 true。真正的 OpenAI 不认此字段,保持 false。
# 注意:thinking mode 下 temperature/top_p 等参数会被静默无视(API 行为,非 codeguard 限制)。
CODEGUARD_DISABLE_THINKING=false

# DeepSeek v4 推理深度(仅 deepseek-v4-pro / deepseek-v4-flash 生效): high(默认) | max。
# "max" 给模型更多思考预算,对复杂代码审查任务可能有更好的推理质量,但会消耗更多 token。
# 留空不设,用模型默认 "high"。非 DeepSeek 端点静默无视。
CODEGUARD_REASONING_EFFORT=

# ReAct Agent 单审查员递归步数上限(默认 48)。每个工具往返耗 2 步,48 步 ≈16-20 次工具调用。
# diff 文件多或上下文复杂时可按需调大;撞上限时走降级兜底(无工具直连)保结果不丢。
CODEGUARD_REACT_RECURSION_LIMIT=48

# LLM 调用最大重试次数
CODEGUARD_MAX_RETRIES=3

# 误报过滤第二段:是否启用 LLM 复核(true/false)。默认 true——精确率最强杠杆(P↑、误报率腰斩),
# 每条存活 issue 各一次复核调用(异源复核请配 CODEGUARD_JUDGE_*,否则回退主模型)。设为 false 关闭。
# 第一段确定性规则始终生效;置信度阈值等在 config/false-positive-rules.yaml 里配,不走环境变量。
CODEGUARD_FP_LLM_VERIFY=true

# 前置摘要阶段开关(true/false)。默认 true:在 ReviewCouncil 前先产出变更摘要,作为 ContextBundle
# 与多 Agent 发现者的共享背景。设为 false 则跳过摘要,ReviewCouncil 直接基于 diff 与轻量上下文运行。
CODEGUARD_ENABLE_SUMMARY=true

# ADR-032 默认编排 profile。目前唯一运行路径为 adr-032:
# summary? → context_provider → ReviewCouncil → self_checker。
# 旧 supervisor 图只保存在 services/agent/legacy/supervisor_graph/ 作为历史参考。
CODEGUARD_REVIEW_ORCHESTRATION=adr-032

# 旧 supervisor 开关已退役,字段暂留兼容旧环境。即使设为 true,ADR-032 默认路径也不会运行旧 Supervisor。
CODEGUARD_ENABLE_SUPERVISOR=false
# 旧 supervisor 轮次上限字段暂留兼容。
CODEGUARD_MAX_REVIEW_ROUNDS=3
# ReviewCouncil EvidenceAgent/ChallengeAgent 的补证轮次上限,第一版默认最多一轮。
CODEGUARD_MAX_EVIDENCE_ROUNDS=1

# Phase 2 风险任务预算：总任务数默认 100，单文件默认 10；只影响深审选择，不改变风险标签。
CODEGUARD_MAX_REVIEW_TASKS=100
CODEGUARD_MAX_TASKS_PER_FILE=10

# 阶段 3:Java 工具服务地址。配置后 pipeline 审查员升级为 ReAct Agent(可调 get_file_content
# 等工具获取 diff 之外的上下文);留空则走无工具直连基准。先启动 Java 工具服务:
#   cd services/gateway && mvn -q package -DskipTests && java -jar target/codeguard-gateway.jar
# 服务默认端口 9090(可用 CODEGUARD_TOOL_SERVER_PORT 覆盖)。仅 --mode pipeline 生效。
CODEGUARD_TOOL_SERVER_URL=
# 工具服务监听端口(Java 侧读取;默认 9090)
CODEGUARD_TOOL_SERVER_PORT=9090

# 【阶段 4】checkpoint 后端: "memory"(内存,进程内) | "sqlite"(本地文件,需 pip install langgraph-checkpoint-sqlite) | 空=不启用(默认)
# 启用后 LangGraph 图的每步 State 自动持久化,API 故障后可用相同 --thread-id 从断点恢复,不丢已收集的上下文。
# 默认空(不启用):向后兼容,无性能开销。需手动显式设为 memory 或 sqlite 才激活。
CODEGUARD_CHECKPOINT_BACKEND=
# SqliteSaver 数据库文件路径(仅 CODEGUARD_CHECKPOINT_BACKEND=sqlite 时生效)
CODEGUARD_CHECKPOINT_DB=codeguard_checkpoints.db

# Human-in-the-loop 开关(true/false)。ADR-032 第一版暂不迁移旧 supervisor finish / reviewer hit-limit
# interrupt 点;字段暂留兼容,当前默认路径会忽略该开关。
CODEGUARD_ENABLE_HITL=false

# ── CI 集成（可选，配置后启用 GitHub webhook 自动审查）──
# CODEGUARD_WEBHOOK_SECRET=whsec_xxxx
# CODEGUARD_GITHUB_APP_ID=123456
# CODEGUARD_GITHUB_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...
# CODEGUARD_GITHUB_TOKEN=ghp_xxxx (git clone 用 token)
# CODEGUARD_MAX_CONCURRENT_REVIEWS=2
# CODEGUARD_WEBHOOK_RATE_LIMIT=0.5 (每秒许可数，Guava 令牌桶，0=不限流)
# CODEGUARD_MAX_DIFF_LINES=5000

# 追踪（可观测性）—— 审查过程可视化
CODEGUARD_TRACE_ENABLED=true
CODEGUARD_TRACE_DIR=trace/
CODEGUARD_TRACE_MAX_LLM_CONTENT=0
